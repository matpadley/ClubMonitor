@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider

@code {
    private bool _authenticated;
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _authenticated = authState.User.Identity?.IsAuthenticated ?? false;
    }
}

@if (!_authenticated)
{
    <Client.Components.Pages.Account.Login />
}
else
{
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h4">Welcome to ClubMonitor!</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}
