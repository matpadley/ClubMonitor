@page "/members/create"
@rendermode InteractiveServer
@attribute [Authorize]
@inject CreateMemberHandler CreateHandler
@inject NavigationManager Nav

<PageTitle>Add Member</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Add Member</MudText>

@if (!_ready)
{
    <MudProgressCircular Indeterminate Class="d-block mx-auto mt-8" />
}
else
{
    <MemberForm Model="@_model"
                OnValidSubmit="HandleSubmit"
                ErrorMessage="@_errorMessage"
                IsSubmitting="@_submitting" />
}

@code {
    private readonly MemberFormModel _model = new();
    private string? _errorMessage;
    private bool _submitting;
    private bool _ready;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ready = true;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit(MemberFormModel model)
    {
        _submitting = true;
        _errorMessage = null;

        try
        {
            await CreateHandler.HandleAsync(new CreateMemberCommand(model.Name, model.Email));
            Nav.NavigateTo("/members");
        }
        catch (DuplicateEmailException)
        {
            _errorMessage = $"A member with email '{model.Email}' already exists.";
        }
        catch (ArgumentException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
}
