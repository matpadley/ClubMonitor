@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">ClubMonitor</MudText>
    </MudAppBar>
    @inject Client.Components.Shared.StubAuthenticationStateProvider AuthProvider
    @inject NavigationManager NavManager

    @code {
        private bool _drawerOpen = true;
        private bool _authenticated;
        protected override async Task OnInitializedAsync()
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            _authenticated = authState.User.Identity?.IsAuthenticated ?? false;
        }
        private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
        private void Logout()
        {
            AuthProvider.SetUser("", Array.Empty<string>());
            NavManager.NavigateTo("/");
        }
    }

    @if (_authenticated)
    {
        <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
            <MudNavMenu>
                <MudNavLink Href="/members"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.People">
                    Members
                </MudNavLink>
                <MudNavLink Href="/clubs"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.Groups">
                    Clubs
                </MudNavLink>
                <MudNavLink Href="/leagues"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.EmojiEvents">
                    Leagues & Cups
                </MudNavLink>
                <MudNavLink Href="/account/profile"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.AccountCircle">
                    Account
                </MudNavLink>
                <MudNavLink Href="#" Icon="@Icons.Material.Filled.Logout" OnClick="Logout">
                    Logout
                </MudNavLink>
            </MudNavMenu>
        </MudDrawer>
    }
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    // ...existing code...
}
}
